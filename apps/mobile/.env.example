# Prototype: shared mock fixtures. Set to false to use the real API (Google sign-in + JWT).
EXPO_PUBLIC_USE_MOCK_API=true

# Base URL for apps/api (no trailing slash). Examples:
# - iOS simulator / web: http://localhost:4000
# - Android emulator: http://10.0.2.2:4000
# - Physical device: http://<your-computer-LAN-IP>:4000
# EXPO_PUBLIC_API_BASE_URL=http://localhost:4000

# Google Sign-In (OAuth client IDs from Google Cloud Console — same project as web VITE_GOOGLE_CLIENT_ID).
# Web client ID is required for id_token with expo-auth-session.
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=....apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=....apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=....apps.googleusercontent.com

# Optional: first-time user role when creating a user via Google (otherwise server defaults apply).
# EXPO_PUBLIC_AUTH_SIGNUP_ROLE=EMPLOYEE

# Optional: which role / tab to prefer when debugging
# EXPO_PUBLIC_INITIAL_ROLE=ADMIN
# EXPO_PUBLIC_INITIAL_ROLE=MANAGER
# EXPO_PUBLIC_INITIAL_ROLE=EMPLOYEE

# Optional: workshop map location for mobile location tab
# EXPO_PUBLIC_WORKSHOP_NAME=AJ Enterprises
# EXPO_PUBLIC_WORKSHOP_LATITUDE=18.6298
# EXPO_PUBLIC_WORKSHOP_LONGITUDE=73.8478
# EXPO_PUBLIC_WORKSHOP_MAP_URL=https://www.google.com/maps?q=18.6298,73.8478
